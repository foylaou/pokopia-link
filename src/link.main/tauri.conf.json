{
  "productName": "Pokopia Link",
  "version": "0.1.0",
  "identifier": "com.pokopia.link",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev",
      "cwd": "../.."
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": "../.."
    },
    "frontendDist": "../../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Pokopia Link",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "center": true
      },
      {
        "label": "float",
        "title": "Pokopia Link - Float",
        "url": "index.html?window=float",
        "width": 280,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": true,
        "center": false,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["pokopia-link"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
