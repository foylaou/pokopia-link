{
  "productName": "Pokopia Link",
  "version": "0.1.0",
  "identifier": "com.pokopia.link",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev",
      "cwd": "../.."
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": "../.."
    },
    "frontendDist": "../../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Pokopia Link",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
